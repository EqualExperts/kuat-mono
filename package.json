{
  "name": "@equal-experts/kuat",
  "version": "0.4.2",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:run": "turbo run test:run",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "agent-rules:sync:upstream": "./scripts/agent-rules/sync-upstream.sh",
    "agent-rules:generate": "node ./scripts/agent-rules/generate-entrypoints.mjs",
    "agent-rules:check": "node ./scripts/agent-rules/generate-entrypoints.mjs --check",
    "agent-rules:sync": "pnpm agent-rules:sync:upstream && pnpm agent-rules:generate"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.2.5",
    "shadcn": "^3.6.1",
    "shadcn-vue": "^2.4.3",
    "turbo": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@8.15.0"
}
