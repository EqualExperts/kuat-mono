{
  "name": "@equal-experts/kuat-core",
  "version": "0.7.0",
  "description": "Core design tokens and CSS variables for the Kuat Design System",
  "license": "MIT",
  "author": "Equal Experts",
  "repository": {
    "type": "git",
    "url": "https://github.com/equalexperts/kuat-mono.git",
    "directory": "packages/kuat-core"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "css-variables",
    "tailwind",
    "equal-experts",
    "kuat"
  ],
  "type": "module",
  "main": "./tailwind.config.ts",
  "types": "./tailwind.config.d.ts",
  "exports": {
    ".": {
      "types": "./tailwind.config.d.ts",
      "default": "./tailwind.config.ts"
    },
    "./variables.css": {
      "style": "./src/variables.css",
      "default": "./src/variables.css"
    },
    "./button-variables.css": {
      "style": "./src/button-variables.css",
      "default": "./src/button-variables.css"
    },
    "./tailwind-preset": {
      "types": "./tailwind.config.d.ts",
      "default": "./tailwind.config.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "tailwind.config.ts",
    "tailwind.config.d.ts",
    "README.md",
    "agent-docs"
  ],
  "scripts": {
    "prepack": "node ../../scripts/agent-docs/bundle-for-core.mjs"
  },
  "devDependencies": {
    "tailwindcss": "^4.0.0"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  }
}
