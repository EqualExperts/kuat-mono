{
  "name": "@equal-experts/kuat-vue",
  "version": "0.9.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./button": {
      "import": "./dist/button.js",
      "types": "./dist/button.d.ts"
    },
    "./accordion": {
      "import": "./dist/accordion.js",
      "types": "./dist/accordion.d.ts"
    },
    "./alert-dialog": {
      "import": "./dist/alert-dialog.js",
      "types": "./dist/alert-dialog.d.ts"
    },
    "./badge": {
      "import": "./dist/badge.js",
      "types": "./dist/badge.d.ts"
    },
    "./button-group": {
      "import": "./dist/button-group.js",
      "types": "./dist/button-group.d.ts"
    },
    "./textarea": {
      "import": "./dist/textarea.js",
      "types": "./dist/textarea.d.ts"
    },
    "./input": {
      "import": "./dist/input.js",
      "types": "./dist/input.d.ts"
    },
    "./field": {
      "import": "./dist/field.js",
      "types": "./dist/field.d.ts"
    },
    "./select": {
      "import": "./dist/select.js",
      "types": "./dist/select.d.ts"
    },
    "./checkbox": {
      "import": "./dist/checkbox.js",
      "types": "./dist/checkbox.d.ts"
    },
    "./radio": {
      "import": "./dist/radio.js",
      "types": "./dist/radio.d.ts"
    },
    "./switch": {
      "import": "./dist/switch.js",
      "types": "./dist/switch.d.ts"
    },
    "./sonner": {
      "import": "./dist/sonner.js",
      "types": "./dist/sonner.d.ts"
    },
    "./toggle": {
      "import": "./dist/toggle.js",
      "types": "./dist/toggle.d.ts"
    },
    "./toggle-group": {
      "import": "./dist/toggle-group.js",
      "types": "./dist/toggle-group.d.ts"
    },
    "./styles": {
      "types": "./dist/style.css.d.ts",
      "default": "./dist/style.css"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "vue",
    "vue3",
    "components",
    "ui",
    "design-system",
    "shadcn-vue",
    "tailwind"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/kuat-mono.git",
    "directory": "packages/kuat-vue"
  },
  "scripts": {
    "build": "vite build && node -e \"const fs=require('node:fs');fs.writeFileSync('dist/style.css.d.ts','declare const stylesheet: string;\\\\nexport default stylesheet;\\\\n');\"",
    "dev": "vite build --watch",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@vueuse/core": "^14.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "embla-carousel-vue": "^8.0.0",
    "tailwind-merge": "^2.2.1",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@equal-experts/kuat-core": "workspace:*",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/vue": "^8.0.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.0",
    "@vue/tsconfig": "^0.5.1",
    "autoprefixer": "^10.4.17",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "vite-plugin-dts": "^3.6.4",
    "vitest": "^2.0.0",
    "vue-tsc": "^1.8.27"
  },
  "peerDependencies": {
    "lucide-vue-next": "^0.344.0 || >=0.400.0",
    "radix-vue": "^1.9.0",
    "reka-ui": "^2.6.1",
    "vue": "^3.4.0"
  }
